# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Para operações server-side (usado no callback Google OAuth para salvar tokens)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Hugging Face (para diarização de áudio - identificar quem fala)
# Gere em: https://huggingface.co/settings/tokens
# Aceite os termos: https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=your-hugging-face-token

# Google Cloud STT (para engine google de transcrição)
# Crie uma service account com permissões: Speech-to-Text User + Storage Object Admin
# GOOGLE_APPLICATION_CREDENTIALS=/caminho/para/service-account.json
# GOOGLE_CLOUD_PROJECT=seu-project-id
# GCS_BUCKET=seu-bucket-para-uploads-temporarios
# GCP_REGION=us-central1

# Deepgram (para engine deepgram de transcrição)
# Crie uma conta e pegue a API key em: https://console.deepgram.com
# $200 em créditos grátis ao se cadastrar
# DEEPGRAM_API_KEY=your-deepgram-api-key

# Groq Cloud (transcrição Whisper)
# Crie uma conta e pegue a API key em: https://console.groq.com
# Usado para: transcrição de áudio (Whisper)
GROQ_API_KEY=your-groq-api-key

# Gemini API (extração de resumo estruturado pós-sessão)
# Crie uma API key em: https://aistudio.google.com/apikey
# Modelo usado: gemini-2.5-flash
GEMINI_API_KEY=your-gemini-api-key

# Google OAuth2 (cada psicóloga vincula sua própria conta Google)
# Crie um OAuth2 Client ID (Web) no Cloud Console: https://console.cloud.google.com/apis/credentials
# Habilite a Google Calendar API: https://console.cloud.google.com/apis/library/calendar-json.googleapis.com
# Redirect URI: {NEXT_PUBLIC_APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Inngest (processamento em background)
# Em desenvolvimento: rode `npx inngest-cli@latest dev` para o dashboard local
# Em produção: configure INNGEST_EVENT_KEY e INNGEST_SIGNING_KEY
# https://www.inngest.com/docs/deploy
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Resend (envio de email — comprovantes de sessão)
# Crie uma conta em: https://resend.com — free tier: 100 emails/dia
# API key: https://resend.com/api-keys
RESEND_API_KEY=
# Domínio verificado no Resend (ex: seu-dominio.com). Sem ele, usa resend.dev (limite de teste)
RESEND_DOMAIN=

# Sentry (monitoramento de erros — opcional)
# Crie um projeto em: https://sentry.io
# Free tier: 5k errors/mês
SENTRY_DSN=
