# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
# ATENÇÃO: use a chave ANON (pública), NUNCA a service_role aqui.
# Esta chave vai pro bundle do browser. A service_role bypassa RLS e
# JAMAIS pode ser exposta no client.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Operações server-side (signed upload URLs, jobs de background, callback Google
# OAuth). Sem prefixo NEXT_PUBLIC_ — fica só no servidor.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Groq Cloud (transcrição Whisper)
# Crie uma conta e pegue a API key em: https://console.groq.com
# Usado para: transcrição de áudio (Whisper)
GROQ_API_KEY=your-groq-api-key

# OpenAI API (extração de resumo estruturado pós-sessão)
# Crie uma API key em: https://platform.openai.com/api-keys
# Modelo usado: gpt-5.2
OPENAI_API_KEY=your-openai-api-key

# Google OAuth2 (cada psicóloga vincula sua própria conta Google)
# Crie um OAuth2 Client ID (Web) no Cloud Console: https://console.cloud.google.com/apis/credentials
# Habilite a Google Calendar API: https://console.cloud.google.com/apis/library/calendar-json.googleapis.com
# Redirect URI: {NEXT_PUBLIC_APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend (envio de email — comprovantes de sessão)
# Crie uma conta em: https://resend.com — free tier: 100 emails/dia
# API key: https://resend.com/api-keys
RESEND_API_KEY=
# Domínio verificado no Resend (ex: seu-dominio.com). Sem ele, usa resend.dev (limite de teste)
RESEND_DOMAIN=

# Criptografia de dados clínicos (AES-256-GCM)
# Protege transcrições, prontuários e dados do paciente no banco.
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ATENÇÃO: se perder esta chave, os dados criptografados ficam irrecuperáveis!
ENCRYPTION_KEY=

# HMAC secret para códigos de verificação de comprovantes (opcional)
# Se não definido, usa SUPABASE_SERVICE_ROLE_KEY como fallback.
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COMPROVANTE_HMAC_SECRET=

# Sentry (monitoramento de erros — opcional)
# Crie um projeto em: https://sentry.io
# Free tier: 5k errors/mês
SENTRY_DSN=
