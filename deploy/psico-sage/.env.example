# === Imagem Docker ===
# Se usar registry: ghcr.io/seu-user/psico-sage:latest
IMAGE=psicosage/app:latest

# === Domínio (Traefik) ===
APP_DOMAIN=app.seudominio.com.br

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Groq (transcrição Whisper) ===
GROQ_API_KEY=

# === OpenAI (extração de resumo) ===
OPENAI_API_KEY=

# === Google OAuth2 ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_APP_URL=https://app.seudominio.com.br

# === Inngest (comunicação com o servidor Inngest) ===
# URL interna do container Inngest (pela rede psicosage-net)
INNGEST_BASE_URL=http://psicosage-inngest:8288
INNGEST_SIGNING_KEY=signkey-prod-xxx
INNGEST_EVENT_KEY=evt-prod-xxx
# URL pela qual o Inngest vai chamar de volta este app
INNGEST_SERVE_HOST=http://psicosage-app:3000

# === Resend (emails) ===
RESEND_API_KEY=
RESEND_DOMAIN=

# === Criptografia de dados clínicos (AES-256-GCM) ===
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# === HMAC para comprovantes (opcional, fallback: SUPABASE_SERVICE_ROLE_KEY) ===
COMPROVANTE_HMAC_SECRET=

# === Sentry (opcional) ===
SENTRY_DSN=
