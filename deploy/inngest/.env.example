# === Domínio do Inngest (Traefik) ===
INNGEST_DOMAIN=inngest.seudominio.com.br

# === Chaves de autenticação (mesmas do app!) ===
INNGEST_SIGNING_KEY=signkey-prod-xxx
INNGEST_EVENT_KEY=evt-prod-xxx

# === Proteger dashboard com basic auth ===
# Gerar com: htpasswd -nB admin
# Escape $ duplicando: $ -> $$
INNGEST_DASHBOARD_AUTH=admin:$$2y$$05$$...
